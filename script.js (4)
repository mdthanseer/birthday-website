// Elements
const loader = document.getElementById("loader");
const main = document.querySelector(".main");
const openBtn = document.getElementById("openBtn");
const giftBtn = document.getElementById("giftBtn");
const letter = document.getElementById("letter");
const music = document.getElementById("music");
const typing = document.querySelector(".typing");

// Birthday Message
const message =
"Happy Birthday, my dear friend! 🥳🎂 Thank you for always being there for me. I hope this year brings you happiness, success, good health, and everything you've dreamed of. Stay happy and keep smiling. Have an amazing birthday! ❤️";

let index = 0;

// Typing Effect
function typeText() {
    if (index < message.length) {
        typing.innerHTML += message.charAt(index);
        index++;
        setTimeout(typeText, 40);
    }
}

// Open Surprise
openBtn.addEventListener("click", () => {

    loader.style.display = "none";
    main.classList.remove("hidden");

    music.play().catch(() => {});

    typeText();

    startSlideshow();
    floatingHearts();
});

// Gift Button
giftBtn.addEventListener("click", () => {

    letter.classList.remove("hidden");

    letter.scrollIntoView({
        behavior: "smooth"
    });

});

// Auto Slideshow
const photos = document.querySelectorAll(".gallery img");

let current = 0;

let slideshowInterval = null;

function startSlideshow(){
    if(slideshowInterval) clearInterval(slideshowInterval);
    
    slideshowInterval = setInterval(() => {
        photos.forEach(img => img.style.opacity = ".35");
        photos[current].style.opacity = "1";
        photos[current].style.transform = "scale(1.05)";

        setTimeout(() => {
            photos[current].style.transform = "scale(1)";
        }, 800);

        current = (current + 1) % photos.length;
    }, 2500);

}

// Floating Hearts

function floatingHearts(){

setInterval(()=>{

const heart=document.createElement("div");

heart.innerHTML="💜";

heart.style.position="fixed";

heart.style.left=Math.random()*100+"vw";

heart.style.bottom="-30px";

heart.style.fontSize=(20+Math.random()*25)+"px";

heart.style.opacity=".9";

heart.style.pointerEvents="none";

heart.style.transition="all 6s linear";

document.body.appendChild(heart);

setTimeout(()=>{

heart.style.bottom="110vh";

heart.style.opacity="0";

},100);

setTimeout(()=>{

heart.remove();

},6500);

},500);

}

